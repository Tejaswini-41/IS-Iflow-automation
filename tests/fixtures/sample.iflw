<?xml version="1.0" encoding="UTF-8"?>
<process xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" id="testProcess" name="Test Process">
    <documentation>This is a sample iFlow for testing purposes.</documentation>
    <collaboration id="collaboration">
        <participant id="participant1" name="Sender" processRef="process1" />
        <participant id="participant2" name="Receiver" processRef="process2" />
    </collaboration>
    <process id="process1" name="Sender Process">
        <startEvent id="startEvent1" name="Start" />
        <serviceTask id="serviceTask1" name="Process Data" />
        <endEvent id="endEvent1" name="End" />
        <sequenceFlow id="flow1" sourceRef="startEvent1" targetRef="serviceTask1" />
        <sequenceFlow id="flow2" sourceRef="serviceTask1" targetRef="endEvent1" />
    </process>
    <process id="process2" name="Receiver Process">
        <startEvent id="startEvent2" name="Start" />
        <endEvent id="endEvent2" name="End" />
        <sequenceFlow id="flow3" sourceRef="startEvent2" targetRef="endEvent2" />
    </process>
</process>